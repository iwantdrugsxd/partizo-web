rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos are public-facing content (shown on deck cards, chat headers, etc.),
    // so anyone can read, but only the owning user can upload to their own folder.
    match /users/{uid}/photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
