# Set NEXT_PUBLIC_DATA_MODE=firebase once these are filled in.
# Leave as "mock" (or omit) to run the app instantly with local fake data + localStorage.
NEXT_PUBLIC_DATA_MODE=mock

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only: lets the /api/upload-photo route verify who's calling it.
# Firebase Console > Project Settings > Service Accounts > Generate new private key,
# then base64-encode the downloaded JSON file, e.g.: base64 -i service-account.json
FIREBASE_SERVICE_ACCOUNT_KEY=

# Server-only: photo storage backend (Supabase, not Firebase Storage).
# Supabase project > Settings > API for the URL + service_role key.
# Create a public Storage bucket (default name "photos") for uploaded profile photos.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=photos
